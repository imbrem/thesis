  rule-set(
    prooftree(t-var),
    prooftree(t-inst),
    prooftree(t-op),
    prooftree(t-let),
    prooftree(t-unit),
    prooftree(t-pair),
    prooftree(t-let-pair),
    prooftree(t-inl),
    prooftree(t-inr),
    prooftree(t-abort),
    prooftree(t-case),
    prooftree(t-iter),
  ),
  caption: [Typing rules for #liter.],
) <fig-expr-typing>
