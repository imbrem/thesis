== Typing

Our typing judgement is #hasty($Œì$, $a$, $A$),
read "in the context $Œì$, the expression $a$ has type $A$".
The rules, given in @fig-expr-typing, are _syntax-directed_:
there is one rule for each production in our grammar.
As before, we work over a fixed _signature_ consisting of: 

- A fixed set of _base types_ $X ‚àà cal(X)$, 
  equipped with a partial order $subty(X, Y)$

- A fixed set of _instructions_ $f ‚àà cal(I)$, 
  each of which has a _source type_ $isrc(f)$ and a _target type_ $itrg(f)$

To state our typing rules, we rely on two auxiliary judgements: 
_subtyping_ #subty($A$, $B$) 
and _weakening_ #wkns($Œì$, $Œî$).
In particular, the subtyping relation from the order on base types $X$ by:

- Taking the empty type $tyempty$ as the bottom element of the order
  -- i.e., as a subtype of all types

- Taking the unit type $tyunit$ as the top element of the order
  -- i.e., as a supertype of all types

- Defining subtyping on products and coproducts pointwise

_Weakening_ is then defined as partial order on typing contexts generated by:

- Weakening individual types (see: #msc[cons])

- Adding new variables of an arbitrary type to the context (see: #msc[drop])

We give these rules, along with our typing rules, in @fig-expr-typing.
In particular:

- #msc[var] looks up a variable's type in the context.

- #msc[op] applies an instruction $f$ to an argument, using the
  instruction's signature given by #msc[inst]
  --
  we note instructions are _contravariant_ in the source type 
  (i.e. if $f$ accepts an $A$ and $subty(A', A)$ then $f$ accepts an $A'$)
  and _covariant_ in the target type
  (i.e. if $f$ returns a $B$ and $subty(B, B')$, 
    then $f$'s return value may be interpreted as a $B'$)

- #msc[let] and #msc[let-pair] bind the result of $a$
  --
  either to a single variable or, by destructuring, to a pair of variables
  --
  in the body.

- #msc[unit] and #msc[pair] introduce the unit and tensor product;
  #msc[let-pair] eliminates the latter.

- #msc[inl], #msc[inr], and #msc[case] introduce and
  eliminate the coproduct, while #msc[abort] eliminates the empty type.

- #msc[iter] types a tail-controlled loop: the body $b$ is evaluated with
  $x$ bound to the current value of type $A$, and either returns a final value
  of type $B$ or a new value of type $A$ to loop with.

#let s-base = rule(
  label: msc("base"),
  $X ‚â§ Y$,
  subty($X$, $Y$),
)
#let s-tensor = rule(
  label: msc("tensor"),
  subty($A$, $A'$), subty($B$, $B'$),
  subty($A tytensor B$, $A' tytensor B'$),
)
#let s-sum = rule(
  label: msc("sum"),
  subty($A$, $A'$), subty($B$, $B'$),
  subty($A tysum B$, $A' tysum B'$),
)
#let s-initial = rule(
  label: msc("initial"),
  subty($tyempty$, $A$),
)
#let s-terminal = rule(
  label: msc("terminal"),
  subty($A$, $tyunit$),
)

#let w-nil = rule(
  label: msc("nil"),
  wkns($¬∑$, $¬∑$),
)
#let w-cons = rule(
  label: msc("cons"),
  wkns($Œì$, $Œî$), subty($A$, $B$),
  wkns($Œì, x : A$, $Œî, x : B$),
)
#let w-drop = rule(
  label: msc("drop"),
  wkns($Œì$, $Œî$),
  wkns($Œì, x : A$, $Œî$),
)

#let t-var = rule(
  label: msc("var"),
  wkns($Œì$, $x : A$),
  hasty($Œì$, $x$, $A$),
)
#let t-inst = rule(
  label: msc("inst"),
  $f ‚àà cal(I)$, $subty(A, isrc(f))$, $subty(itrg(f), B)$,
  instty($f$, $A$, $B$),
)
#let t-op = rule(
  label: msc("op"),
  instty($f$, $A$, $B$), hasty($Œì$, $a$, $A$),
  hasty($Œì$, $f med a$, $B$),
)
#let t-let = rule(
  label: msc("let"),
  hasty($Œì$, $a$, $A$), hasty($Œì, x : A$, $b$, $B$),
  hasty($Œì$, letx($x$, $a$, $b$), $B$),
)
#let t-unit = rule(
  label: msc("unit"),
  hasty($Œì$, $()$, $tyunit$),
)
#let t-pair = rule(
  label: msc("pair"),
  hasty($Œì$, $a$, $A$), hasty($Œì$, $b$, $B$),
  hasty($Œì$, $(a, b)$, $A tytensor B$),
)
#let t-let-pair = rule(
  label: msc("let-pair"),
  hasty($Œì$, $a$, $A tytensor B$), hasty($Œì, x : A, y : B$, $c$, $C$),
  hasty($Œì$, letx($(x, y)$, $a$, $c$), $C$),
)
#let t-inl = rule(
  label: msc("inl"),
  hasty($Œì$, $a$, $A$),
  hasty($Œì$, linl($a$), $A tysum B$),
)
#let t-inr = rule(
  label: msc("inr"),
  hasty($Œì$, $b$, $B$),
  hasty($Œì$, linr($b$), $A tysum B$),
)
#let t-abort = rule(
  label: msc("abort"),
  hasty($Œì$, $a$, $tyempty$),
  hasty($Œì$, labort($a$), $C$),
)
#let t-case = rule(
  label: msc("case"),
  hasty($Œì$, $e$, $A tysum B$),
  hasty($Œì, x : A$, $a$, $C$),
  hasty($Œì, y : B$, $b$, $C$),
  hasty($Œì$, casex($e$, $x$, $a$, $y$, $b$), $C$),
)
#let t-iter = rule(
  label: msc("iter"),
  hasty($Œì$, $a$, $A$),
  hasty($Œì, x : A$, $b$, $B tysum A$),
  hasty($Œì$, iterx($a$, $x$, $b$), $B$),
)

#figure(
  stack(
    spacing: 1.5em,
    rule-set(
      prooftree(s-base),
      prooftree(s-tensor),
      prooftree(s-sum),
      prooftree(s-initial),
      prooftree(s-terminal),
    ),
    rule-set(
      prooftree(w-nil),
      prooftree(w-cons),
      prooftree(w-drop),
    ),
    rule-set(
      prooftree(t-var),
      prooftree(t-inst),
      prooftree(t-op),
      prooftree(t-let),
      prooftree(t-unit),
      prooftree(t-pair),
      prooftree(t-let-pair),
      prooftree(t-inl),
      prooftree(t-inr),
      prooftree(t-abort),
      prooftree(t-case),
      prooftree(t-iter),
    ),
  ),
  caption: [Typing rules for #liter, including subtyping and weakening.],
