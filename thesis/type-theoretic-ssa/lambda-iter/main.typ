#todo[each instruction $f âˆˆ cal(I)$ carries an effect #ieff($f$); the effectful judgement #hastye($Î“$, $Îµ$, $a$, $A$) bounds the effects of $a$ above by $Îµ$, so pure constructors may be typed at any $Îµ$]

#todo[#effiter($Îµ$) is a monotone closure operator on #effs giving the effect of iterating an $Îµ$-effectful body: extensive ($Îµ â‰¤ effiter(Îµ)$) and idempotent ($effiter(effiter(Îµ)) = effiter(Îµ)$)]

#let te-var = rule(
  label: msc("var"),
  wkns($Î“$, $x : A$),
  hastye($Î“$, $Îµ$, $x$, $A$),
)
#let te-inst = rule(
  label: msc("inst"),
  $f âˆˆ cal(I)$, $isrc(f) = A$, $itrg(f) = B$, $ieff(f) â‰¤ Îµ$,
  insttye($f$, $A$, $Îµ$, $B$),
)
#let te-op = rule(
  label: msc("op"),
  insttye($f$, $A$, $Îµ$, $B$), hastye($Î“$, $Îµ$, $a$, $A$),
  hastye($Î“$, $Îµ$, $f med a$, $B$),
)
#let te-let = rule(
  label: msc("let"),
  hastye($Î“$, $Îµ$, $a$, $A$), hastye($Î“, x : A$, $Îµ$, $b$, $B$),
  hastye($Î“$, $Îµ$, letx($x$, $a$, $b$), $B$),
)
#let te-unit = rule(
  label: msc("unit"),
  hastye($Î“$, $Îµ$, $()$, $tyunit$),
)
#let te-pair = rule(
  label: msc("pair"),
  hastye($Î“$, $Îµ$, $a$, $A$), hastye($Î“$, $Îµ$, $b$, $B$),
  hastye($Î“$, $Îµ$, $(a, b)$, $A tytensor B$),
)
#let te-let-pair = rule(
  label: msc("let-pair"),
  hastye($Î“$, $Îµ$, $a$, $A tytensor B$), hastye($Î“, x : A, y : B$, $Îµ$, $c$, $C$),
  hastye($Î“$, $Îµ$, letx($(x, y)$, $a$, $c$), $C$),
)
#let te-inl = rule(
  label: msc("inl"),
  hastye($Î“$, $Îµ$, $a$, $A$),
  hastye($Î“$, $Îµ$, linl($a$), $A tysum B$),
)
#let te-inr = rule(
  label: msc("inr"),
  hastye($Î“$, $Îµ$, $b$, $B$),
  hastye($Î“$, $Îµ$, linr($b$), $A tysum B$),
)
#let te-abort = rule(
  label: msc("abort"),
  hastye($Î“$, $Îµ$, $a$, $tyempty$),
  hastye($Î“$, $Îµ$, labort($a$), $C$),
)
#let te-case = rule(
  label: msc("case"),
  hastye($Î“$, $Îµ$, $e$, $A tysum B$),
  hastye($Î“, x : A$, $Îµ$, $a$, $C$),
  hastye($Î“, y : B$, $Îµ$, $b$, $C$),
  hastye($Î“$, $Îµ$, casex($e$, $x$, $a$, $y$, $b$), $C$),
)
#let te-iter = rule(
  label: msc("iter"),
  hastye($Î“$, $Îµ$, $a$, $A$),
  hastye($Î“, x : A$, $Îµ$, $b$, $B tysum A$),
  hastye($Î“$, effiter($Îµ$), iterx($a$, $x$, $b$), $B$),
)

