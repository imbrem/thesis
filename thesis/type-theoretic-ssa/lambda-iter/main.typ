== Syntactic Metatheory

#todo[explain weakening: it folds context weakening and subtyping on the result type into a single admissible rule]

#lemma("Weakening")[
  If #wkns($Î“$, $Î”$), #subty($A$, $B$), and #hasty($Î”$, $a$, $A$),
  then #hasty($Î“$, $a$, $B$).
]

#todo[explain the substitution typing judgement #issub($Î“$, $Ïƒ$, $Î”$): a substitution $Ïƒ$ assigns to each variable of $Î”$ a term well-typed over $Î“$]

#let sub-nil = rule(
  label: msc("nil"),
  issub($Î“$, $Â·$, $Â·$),
)
#let sub-cons = rule(
  label: msc("cons"),
  issub($Î“$, $Ïƒ$, $Î”$), hasty($Î“$, $a$, $A$), $x âˆ‰ Ïƒ$,
  issub($Î“$, $Ïƒ, x â†¦ a$, $Î”, x : A$),
)

